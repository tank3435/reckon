DATABASE_URL=postgresql+asyncpg://reckon:reckon@localhost:5432/reckon

# External data source API keys (add as you integrate)
FRED_API_KEY=
WORLD_BANK_API_KEY=
GDELT_API_KEY=
OPENWEATHER_API_KEY=
# Free token from https://metaculus.com/aib (required for Metaculus ingestion)
METACULUS_API_TOKEN=
# Register free at https://acleddata.com/user/register (required for ACLED ingestion)
ACLED_EMAIL=
ACLED_PASSWORD=

# Geocoding
GEOCODING_API_KEY=

# Optional: override tier weights (comma-separated: economic,political,military,existential)
# TIER_WEIGHTS=0.20,0.25,0.25,0.30
